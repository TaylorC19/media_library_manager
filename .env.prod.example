# Production-style deployment for the Go app (`docker compose -f docker-compose.prod.yml`).
# Copy to `.env.prod` and adjust. See `internal/config/config.go` for all supported variables.

APP_ENV=production

# HTTP
PORT=8080
DEFAULT_LOCALE=en
SESSION_COOKIE_NAME=mlm_session
# Session lifetime in hours (default in config: 336 = 14 days).
SESSION_TTL_HOURS=720
SESSION_COOKIE_SECURE=true

# MongoDB — set one of:
# - Atlas: mongodb+srv://...
# - Docker profile `mongo`: mongodb://mongo:27017
MONGODB_URI=
MONGODB_DATABASE=media_library

# Providers (optional; search/lookup degrade when unset)
TMDB_API_KEY=
RAWG_API_KEY=
DISCOGS_TOKEN=
MUSICBRAINZ_USER_AGENT=MediaLibraryManager/1.0 (https://example.com/contact)

# Provider reliability
PROVIDER_CACHE_VERSION=v1
PROVIDER_CACHE_SEARCH_TTL_MS=43200000
PROVIDER_CACHE_NEGATIVE_SEARCH_TTL_MS=900000
PROVIDER_CACHE_DETAIL_TTL_MS=604800000
PROVIDER_CACHE_NEGATIVE_DETAIL_TTL_MS=3600000
PROVIDER_CACHE_BARCODE_TTL_MS=604800000
PROVIDER_CACHE_NEGATIVE_BARCODE_TTL_MS=3600000
MUSICBRAINZ_MIN_INTERVAL_MS=1100
MUSICBRAINZ_RATE_LIMIT_COOLDOWN_MS=5000
MUSICBRAINZ_RETRYABLE_COOLDOWN_MS=2000
