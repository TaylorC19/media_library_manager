NODE_ENV=production

# Web
# Public browser-facing URL for the API. If you are not using a reverse proxy,
# this can be the API server URL with an explicit port.
WEB_PORT=3000
NEXT_PUBLIC_API_BASE_URL=https://api.example.com
INTERNAL_API_BASE_URL=http://api:4000

# API
API_PORT=4000
APP_BASE_URL=https://app.example.com
SESSION_COOKIE_NAME=mlib_session
SESSION_SECRET=replace_with_a_long_random_secret
SESSION_TTL_DAYS=30
CORS_ORIGIN=https://app.example.com

# Mongo
# Choose one:
# - MongoDB Atlas: mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority
# - Self-hosted Mongo in docker-compose.prod.yml: mongodb://mongo:27017/media_library
# - External Mongo on your network: mongodb://<host>:27017/media_library
MONGODB_URL=

# TMDB
TMDB_API_KEY=
TMDB_BASE_URL=https://api.themoviedb.org/3

# MusicBrainz
MUSICBRAINZ_BASE_URL=https://musicbrainz.org/ws/2
MUSICBRAINZ_USER_AGENT=media-library/0.1.0 (your-contact-or-repo-url)
MUSICBRAINZ_MIN_INTERVAL_MS=1100
MUSICBRAINZ_RATE_LIMIT_COOLDOWN_MS=5000
MUSICBRAINZ_RETRYABLE_COOLDOWN_MS=2000

# Discogs
DISCOGS_TOKEN=
DISCOGS_BASE_URL=https://api.discogs.com

# Open Library
OPENLIBRARY_BASE_URL=https://openlibrary.org

# RAWG
RAWG_API_KEY=
RAWG_BASE_URL=https://api.rawg.io/api

# Provider reliability
PROVIDER_CACHE_VERSION=v3
PROVIDER_CACHE_SEARCH_TTL_MS=43200000
PROVIDER_CACHE_DETAIL_TTL_MS=604800000
PROVIDER_CACHE_BARCODE_TTL_MS=604800000
PROVIDER_CACHE_NEGATIVE_SEARCH_TTL_MS=900000
PROVIDER_CACHE_NEGATIVE_DETAIL_TTL_MS=3600000
PROVIDER_CACHE_NEGATIVE_BARCODE_TTL_MS=3600000
