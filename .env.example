# Go app runtime
APP_ENV=development
PORT=8080
DEFAULT_LOCALE=en

# Sessions (HTTP-only cookie). Defaults match internal/config if omitted.
SESSION_COOKIE_NAME=mlm_session
SESSION_TTL_HOURS=336
# Set true behind HTTPS in production (`docker-compose.prod.yml` sets this in `.env.prod`).
SESSION_COOKIE_SECURE=false

# MongoDB (local dev: `./scripts/dev-db-up.sh` exposes Mongo on localhost:27017)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=media_library

# Provider search (optional; movie/TV and games need keys to return results)
TMDB_API_KEY=
RAWG_API_KEY=
DISCOGS_TOKEN=
# MusicBrainz expects a descriptive User-Agent string.
MUSICBRAINZ_USER_AGENT=MediaLibraryManager/1.0 (https://example.invalid/contact)

# Provider reliability
PROVIDER_CACHE_VERSION=v1
PROVIDER_CACHE_SEARCH_TTL_MS=43200000
PROVIDER_CACHE_NEGATIVE_SEARCH_TTL_MS=900000
PROVIDER_CACHE_DETAIL_TTL_MS=604800000
PROVIDER_CACHE_NEGATIVE_DETAIL_TTL_MS=3600000
PROVIDER_CACHE_BARCODE_TTL_MS=604800000
PROVIDER_CACHE_NEGATIVE_BARCODE_TTL_MS=3600000
MUSICBRAINZ_MIN_INTERVAL_MS=1100
MUSICBRAINZ_RATE_LIMIT_COOLDOWN_MS=5000
MUSICBRAINZ_RETRYABLE_COOLDOWN_MS=2000
