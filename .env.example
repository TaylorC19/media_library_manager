NODE_ENV=development

# Web
WEB_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
INTERNAL_API_BASE_URL=http://localhost:4000

# API
API_PORT=4000
APP_BASE_URL=http://localhost:3000
SESSION_COOKIE_NAME=mlib_session
SESSION_SECRET=replace_me
SESSION_TTL_DAYS=30
CORS_ORIGIN=http://localhost:3000

# Mongo
MONGODB_URL=mongodb://localhost:27017/media_library

# TMDB
TMDB_API_KEY=
TMDB_BASE_URL=https://api.themoviedb.org/3

# MusicBrainz
MUSICBRAINZ_BASE_URL=https://musicbrainz.org/ws/2
MUSICBRAINZ_USER_AGENT=media-library/0.1.0 (your-contact-or-repo-url)
MUSICBRAINZ_MIN_INTERVAL_MS=1100
MUSICBRAINZ_RATE_LIMIT_COOLDOWN_MS=5000
MUSICBRAINZ_RETRYABLE_COOLDOWN_MS=2000

# Discogs
DISCOGS_TOKEN=
DISCOGS_BASE_URL=https://api.discogs.com

# Open Library
OPENLIBRARY_BASE_URL=https://openlibrary.org

# RAWG
RAWG_API_KEY=
RAWG_BASE_URL=https://api.rawg.io/api

# Provider reliability
PROVIDER_CACHE_VERSION=v3
PROVIDER_CACHE_SEARCH_TTL_MS=43200000
PROVIDER_CACHE_DETAIL_TTL_MS=604800000
PROVIDER_CACHE_BARCODE_TTL_MS=604800000
PROVIDER_CACHE_NEGATIVE_SEARCH_TTL_MS=900000
PROVIDER_CACHE_NEGATIVE_DETAIL_TTL_MS=3600000
PROVIDER_CACHE_NEGATIVE_BARCODE_TTL_MS=3600000
